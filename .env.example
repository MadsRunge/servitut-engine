ENVIRONMENT=development
SECRET_KEY=change-me-in-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/servitut
REDIS_URL=redis://127.0.0.1:6379/0

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
MODEL=claude-sonnet-4-6
EXTRACTION_LLM_PROVIDER=
EXTRACTION_MODEL=
REPORT_LLM_PROVIDER=
REPORT_MODEL=
LLM_TIMEOUT_SECONDS=120

STORAGE_DIR=storage
PROMPTS_DIR=prompts
MAX_CHUNK_SIZE=2000
CHUNK_OVERLAP=200
EXTRACTION_MAX_CONCURRENCY=4

OCR_LANGUAGE=dan+eng
OCR_DESKEW=true
OCR_JOBS=0
OCR_BATCH_SIZE=80

APP_PIN=
TINGLYSNING_DOWNLOAD_DIR=~/Downloads
TMV_JOB_DOWNLOAD_DIR=~/Downloads/servitut-engine-tmv
